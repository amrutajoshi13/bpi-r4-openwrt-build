
config webOption 'sensorType'
	option DIO '2'
	#option scheduledEvent '1'

config webOption 'actionEventAddType'
	option DIO 'DIO Event'
	#option scheduledEvent 'Sheduled Event'
	option Modbus 'Modbus Alarm'
	option AIO 'Analog Input Alarm'
	#option Temperature 'Temperature Alarm'

config webOption 'actionType'
	option DIO '1'
	option sms '1'
	option email '1'

config mqtt 'topics'
	option numberOfSubTopics '4'
	option subTopic1 'IOCard1/P530/E/Alarm/EnergyMeterDataBL'
	option subTopic2 'IOCard1/P530/D/DIOEvent'
	option subTopic3 'IOCard1/P530/T/TemperatureEvent'
	option subTopic4 'IOCard1/P530/A/AIOEvent'
	option numberOfPubTopics '1'
	option pubTopic1 'IOCard1/P530/IREQ/Command'

config general 'general'
	option logFileDir '/tmp/Log/BLCControlApp/'
	option logFileName 'log.txt'

