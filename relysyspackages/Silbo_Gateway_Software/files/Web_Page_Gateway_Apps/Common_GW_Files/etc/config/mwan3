
config globals 'globals'
	option mmx_mask '0x3F00'
	option rtmon_interval '5'

config member 'WAN5_failover'
	option interface 'WAN5'
	option metric '5'

config interface 'WAN5'
	option enabled '1'
	option track_method 'ping'
	list track_ip '8.8.8.8'
	list track_ip '8.8.4.4'
	option family 'ipv4'
	option reliability '1'
	option count '1'
	option down '2'
	option up '2'
	list flush_conntrack 'ifup'
	list flush_conntrack 'ifdown'
	list flush_conntrack 'connected'
	list flush_conntrack 'disconnected'
	option initial_state 'offline'

config policy 'failover'
	option last_resort 'default'
	list use_member 'EWAN5_failover'
	list use_member 'WAN4_failover'
	list use_member 'WAN3_failover'
	list use_member 'CWAN1_0_failover'
	list use_member 'CWAN1_1_failover'

config member 'EWAN5_failover'
	option interface 'EWAN5'
	option metric '1'

config interface 'EWAN5'
	option enabled '1'
	option track_method 'ping'
	list track_ip '8.8.8.8'
	list track_ip '8.8.4.4'
	option family 'ipv4'
	option reliability '1'
	option count '3'
	option down '3'
	option up '3'
	list flush_conntrack 'ifup'
	list flush_conntrack 'ifdown'
	list flush_conntrack 'connected'
	list flush_conntrack 'disconnected'
	option initial_state 'offline'

config member 'WAN4_failover'
	option interface 'WAN4'
	option metric '4'

config interface 'WAN4'
	option enabled '1'
	option track_method 'ping'
	list track_ip '8.8.8.8'
	list track_ip '8.8.4.4'
	option family 'ipv4'
	option reliability '1'
	option count '1'
	option down '2'
	option up '2'
	list flush_conntrack 'ifup'
	list flush_conntrack 'ifdown'
	list flush_conntrack 'connected'
	list flush_conntrack 'disconnected'
	option initial_state 'offline'

config member 'WAN3_failover'
	option interface 'WAN3'
	option metric '5'

config interface 'WAN3'
	option enabled '1'
	option track_method 'ping'
	list track_ip '8.8.8.8'
	list track_ip '8.8.4.4'
	option family 'ipv4'
	option reliability '1'
	option count '1'
	option down '2'
	option up '2'
	list flush_conntrack 'ifup'
	list flush_conntrack 'ifdown'
	list flush_conntrack 'connected'
	list flush_conntrack 'disconnected'
	option initial_state 'offline'

config rule 'default_rule_v4'
	option dest_ip '0.0.0.0/0'
	option family 'ipv4'
	option use_policy 'failover'

config rule 'default_rule_v6'
	option dest_ip '::/0'
	option family 'ipv6'
	option use_policy 'failover'

config member 'CWAN1_0_failover'
	option interface 'CWAN1_0'
	option metric '2'

config interface 'CWAN1_0'
	option enabled '1'
	option track_method 'ping'
	list track_ip '8.8.8.8'
	list track_ip '8.8.8.8'
	option family 'ipv4'
	option reliability '1'
	option count '3'
	option down '3'
	option up '3'
	list flush_conntrack 'ifup'
	list flush_conntrack 'ifdown'
	list flush_conntrack 'connected'
	list flush_conntrack 'disconnected'
	option timeout '4'
	option interval '2'

config member 'CWAN1_1_failover'
	option interface 'CWAN1_1'
	option metric '3'

config interface 'CWAN1_1'
	option enabled '1'
	option track_method 'ping'
	list track_ip '8.8.8.8'
	list track_ip '8.8.4.4'
	option family 'ipv4'
	option reliability '1'
	option count '3'
