
config defaults 'def'
	option syn_flood '1'
	option input 'REJECT'
	option output 'ACCEPT'
	option forward 'REJECT'

config rule 'ipsec_rule1'
	option name 'Allow-IKE-input'
	option proto 'udp'
	option dest_port '500'
	option target 'ACCEPT'
	option src 'EWAN5'

config rule 'ipsec_rule2'
	option name 'Allow-IKE-input'
	option proto 'udp'
	option dest_port '4500'
	option target 'ACCEPT'
	option src 'EWAN5'

config rule 'ipsec_rule3'
	option name 'Allow-IPSec-ESP'
	option dest 'SW_LAN'
	option proto 'esp'
	option target 'ACCEPT'
	option src 'EWAN5'

config rule 'ipsec_rule4'
	option name 'Allow-IPSec-Forward-IN'
	option src '*'
	option dest '*'
	option proto 'all'
	option target 'ACCEPT'
	option extra '-m policy --dir in  --pol ipsec'
	option family 'ipv4'

config rule 'ipsec_rule5'
	option name 'Allow-IPSec-Forward-OUT'
	option src '*'
	option dest '*'
	option proto 'all'
	option target 'ACCEPT'
	option extra '-m policy --dir out --pol ipsec'
	option family 'ipv4'

config rule 'ipsec_rule6'
	option name 'Allow-IPsec-Policy-In'
	option family 'ipv4'
	option src '*'
	option proto 'all'
	option target 'ACCEPT'
	option extra '-m policy --dir in --pol ipsec'

config include
	option path '/etc/firewall.user'

config zone 'wifi'
	option name 'ra0'
	option input 'ACCEPT'
	option output 'ACCEPT'
	option forward 'REJECT'
	option network 'ra0'
	option masq '1'
	option mtu_fix '1'
	option extra_src '-m policy --dir in --pol none'
	option extra_dest '-m policy --dir out --pol none'

config rule 'udp_DHCPwan6c1_replies'
	option target 'ACCEPT'
	option src 'wan6c1'
	option proto 'udp'
	option dest_port '546'
	option name 'Allow DHCPwan6c1 replies'
	option family 'ipv6'
	option src_port '547'

config rule 'udp_DHCPwan6c2_replies'
