config category 'Config'
    list source 'config'
    option MAXRecords '500'

config category 'Connections'
    list source 'dropbear'
    list source 'modem'
    list source 'openvpn'
    list source 'ipsec'
    list source 'pppd'
    list source 'easycwmpd'
    list source 'dnsmasq'
    list source 'openwisp'
    list source 'ethernet'
    list source 'wifi'
    option MAXRecords '500'
    
config category 'System'
    list source 'reboot'
    option MAXRecords '500'

config category 'Network'
    list source 'smsd'
    list source 'netifd'
    list source 'mwan3'
    list source 'mwan3track'
    option MAXRecords '500'
    
config category 'Events'
    list source 'ntpsync'
    option MAXRecords '500'


config source 'smsd'
        list include 'SMS sent'
        list include 'SMS received'
        list include 'Sending SMS'
        
config source 'netifd'        
        list include 'is now down'
        list include 'is now up'

config source 'openvpn'
        list include 'TUN/TAP device'
        list include 'net_addr_ptp_v4_add'
        list include 'Initialization Sequence Completed'

config source 'dnsmasq'
        list include 'DHCP, IP range'
        list include 'using nameserver'
        list include 'DHCPREQUEST'
        list include 'DHCPNAK'
        list include 'DHCPDISCOVER'
        list include 'DHCPOFFER'
        list include 'DHCPACK'

config source 'ipsec'
        list include 'IKE_SA'
        
config source 'pppd'
        list include 'CHAP'
        list include 'MPPE'
        
config source 'openwisp'
        list include 'Waiting'
        list include 'Registering'
        list include 'New device registered'
        list include 'Configuration'
        list include 'Called post-reload-hook'
        list include 'Existing device registered'
        list include 'deleted'

config source 'mwan3'
        list include 'ifup'
        list include 'ifdown'
        list include 'Starting tracker'
        list include 'Connection tracking'
        list include 'offline'

config source 'mwan3track'
        list include 'ifup'
        list include 'ifdown'
        list include 'Starting tracker'
        list include 'Connection tracking'
        list include 'offline'
