#!/usr/bin/haserl
<%
  # Set the path of the file to read
  TARGET_FILE="/etc/config/webserverconfig"

  # Print HTTP headers
  /usr/bin/printf "Status: 200 OK\r\n"
  /usr/bin/printf "Content-Type: text/plain\r\n\r\n"

  # Check if the file exists
  if [ ! -f "$TARGET_FILE" ]; then
    echo "Error: File not found at $TARGET_FILE"
    exit 1
  fi

  # Output the file content
  cat "$TARGET_FILE"
%>
